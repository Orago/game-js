{
	"compilerOptions": {
		"target": "es2022",
		"lib": [
			"es6",
			"DOM",
			"ES2022"
		],
		"noLib": false,
		"module": "ESNEXT",
		"rootDir": "./src",
		"paths": {},
		"moduleResolution": "bundler",
		"declaration": true,
		"outDir": "./js",
		"preserveConstEnums": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"downlevelIteration": true,
	},
	"include": [
		"src"
	]
}