{
	"name": "@orago/game",
	"version": "0.0.89",
	"description": "Orago's Game library",
	"type": "module",
	"scripts": {
		"build": "npm run build-cjs & npm run build-esm & npm run build-umd & npm run build-browser-esm & npm run build-browser-umd",
		"build-cjs": "npx tsc --module commonjs --moduleResolution node --outDir dist/cjs/",
		"build-esm": "npx tsc --module es2022 --outDir dist/esm/",
		"build-umd": "npx tsc --module umd --outDir dist/umd/ --declarationDir dist/umd",
		"build-browser-esm": "rollup --config rollup.config.browser.esm.js --configPlugin typescript --name oragame",
		"build-browser-umd": "rollup --config rollup.config.browser.umd.js --configPlugin typescript --name oragame",
		"bb": "npm run build-browser-umd",
		"test": "echo \"Error: no test specified\" && exit 1"
	},
	"author": "Orago",
	"license": "ISC",
	"exports": {
		".": {
			"default": {
				"types": "./dist/types/index.d.ts",
				"import": "./dist/esm/index.js",
				"require": "./dist/cjs/index.js"
			}
		},
		"./client": {
			"default": {
				"types": "./dist/types/client/index.d.ts",
				"import": "./dist/esm/client/index.js",
				"require": "./dist/cjs/client/index.js"
			}
		},
		"./ecs": {
			"default": {
				"types": "./dist/types/ecs/index.d.ts",
				"import": "./dist/esm/ecs/index.js",
				"require": "./dist/cjs/ecs/index.js"
			}
		},
		"./client/plugins": {
			"default": {
				"types": "./dist/types/client/plugins/index.d.ts",
				"import": "./dist/esm/client/plugins/index.js",
				"require": "./dist/cjs/client/plugins/index.js"
			}
		}
	},
	"typesVersions": {
		"*": {
			"*": [
				"./src/*"
			]
		}
	},
	"dependencies": {
		"@orago/ecs": "^0.0.20",
		"@orago/lib": "^0.0.42"
	},
	"optionalDependencies": {
		"@orago/dom": "^0.0.47"
	},
	"devDependencies": {
		"@rollup/plugin-node-resolve": "15.2.3",
		"@rollup/plugin-typescript": "11.1.6",
		"@types/uuid": "^9.0.8",
		"rollup": "^4.52.4",
		"typescript": "^5.7.2"
	}
}
