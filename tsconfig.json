{
	"compilerOptions": {
		"target": "es6",
		"lib": [
			"es6",
			"DOM",
			"ES2022"
		],
		"noLib": false,
		"module": "ES6",
		"rootDir": "./src",
		"moduleResolution": "node",
		"paths": {
			"*": [
				"./node_modules/*"
			]
		},
		"declaration": true,
		"outDir": "./js",
		"preserveConstEnums": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true
	},
	"include": [
		"./src"
	]
}